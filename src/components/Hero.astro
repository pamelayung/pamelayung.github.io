---
import { siteConfig } from "../config";
---

<section class="min-h-[90vh] flex items-center px-8 sm:px-12 md:px-16 lg:px-24">
  <div class="max-w-6xl">
    <p class="text-4xl sm:text-5xl md:text-6xl font-bold text-gray-700 mb-6">
      Hello! 👋
    </p>

    <h1 class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-bold tracking-tight text-gray-900 leading-none">
      I'm
      <span
        class="ml-4"
        style={`color: ${siteConfig.accentColor}`}
      >
        {siteConfig.name}
      </span>
    </h1>

    <p class="mt-8 text-xl sm:text-2xl md:text-3xl text-gray-600 font-medium">
      {siteConfig.title}
    </p>

    <div class="flex gap-6 mt-16 text-gray-600">
      <a href={`mailto:${siteConfig.social.email}`} target="_blank" aria-label="Email">
        Email
      </a>
      <a href={siteConfig.social.linkedin} target="_blank" aria-label="LinkedIn">
        LinkedIn
      </a>
      <a href={siteConfig.social.github} target="_blank" aria-label="GitHub">
        GitHub
      </a>
    </div>
  </div>
</section>